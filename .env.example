# Copy this file to .env and fill in the values for your environment.
# `python-dotenv` (pulled in by `uv sync`) auto-loads .env when the CLI
# starts, so anything you set here becomes an environment variable for
# both `minimal-agent run …` and `minimal-agent serve`.
#
# Only FEISHU_APP_ID and FEISHU_APP_SECRET are strictly required.

# ---------------------------------------------------------------------------
# Required: Feishu (Lark) self-built app credentials
# ---------------------------------------------------------------------------
# Get these from https://open.feishu.cn/app -> your app -> Credentials & Basic Info
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Bot tuning (optional; sensible defaults are baked in)
# ---------------------------------------------------------------------------
# `all` (default) replies to every event Feishu delivers; `mentions_or_p2p`
# replies in P2P chats and only to @-mentioned messages in groups.
# FEISHU_RESPOND_MODE=all

# Required only when FEISHU_RESPOND_MODE=mentions_or_p2p so the bot can
# recognise its own @-mention. Find it via the open API or `gh` debugging.
# FEISHU_BOT_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Worker pool size for offloading LLM/image calls (default: 4).
# FEISHU_WORKER_THREADS=4

# LRU capacity for event_id deduplication (default: 1024).
# FEISHU_DEDUP_CAPACITY=1024

# Set to 1 for verbose lark-oapi SDK logs.
# FEISHU_DEBUG=1

# ---------------------------------------------------------------------------
# Conversation history context (loaded when @-mentioned or in P2P)
# ---------------------------------------------------------------------------
# When the bot is @-mentioned in a group (requires FEISHU_BOT_OPEN_ID) or
# receives a P2P message, it can pull recent messages from that chat via
# im.v1.message.list and pass them to the LLM as conversation context.
# Requires the `im:message:readonly` (or `im:message`) scope on the
# self-built app. Set to 0 to disable entirely (default: 1).
# FEISHU_HISTORY_ENABLED=1

# Max number of recent messages to include (default: 20; Feishu caps at 50).
# FEISHU_HISTORY_COUNT=20

# Only include messages from the last N minutes (default: 60). Set to 0 for
# no time window.
# FEISHU_HISTORY_WINDOW_MINUTES=60

# Hard cap on how many historical image attachments to download + include
# (default: 3). Counted globally across all history messages, newest first.
# Ignored when T2T_MULTIMODAL is not set.
# FEISHU_HISTORY_MAX_IMAGES=3

# ---------------------------------------------------------------------------
# `run` mode: target chat for one-shot delivery
# ---------------------------------------------------------------------------
# Required for `minimal-agent run …` unless you pass --chat-id or --no-feishu.
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Multimodal images endpoint (used by t2i / it2i)
# ---------------------------------------------------------------------------
# Defaults below match the local vllm-omni instance from docker-compose.yml.
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=dummy
# OPENAI_MODEL=model

# ---------------------------------------------------------------------------
# Text chat-completions endpoint (used by t2t / it2t)
# ---------------------------------------------------------------------------
# All three fall back to OPENAI_* above when unset, so leave commented out
# if you're running a single endpoint that handles both. Otherwise point
# them at your dedicated text/VL chat server (e.g. llama.cpp).
# T2T_OPENAI_BASE_URL=http://127.0.0.1:8001/v1
# T2T_OPENAI_API_KEY=dummy
# T2T_OPENAI_MODEL=qwen3-30b-a3b

# Sampling temperature for t2t / it2t (default: 0.7). GPT_TEMPERATURE is
# accepted as a legacy alias.
# T2T_TEMPERATURE=0.7

# Set to 1 if the T2T endpoint is multimodal (accepts image_url message
# parts). Required to feed *historical* images back to the LLM as
# context — when unset, history images are dropped and a single WARNING
# is logged per request. it2t (current-turn image) is independent of
# this flag and will fail at the backend if the endpoint can't see
# images. Default: 0.
# T2T_MULTIMODAL=0

# Set to 1 to keep the model's <think>...</think> reasoning blocks
# (default: 0, i.e. stripped before reply).
# LLM_ENABLE_THINKING=0

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# Where generated images from the `run` CLI are saved (default ./output_images).
# OUTPUT_DIR=./output_images

# Set to 1 to opt into LLM-based tool routing instead of the keyword router.
# When enabled the router uses OpenAI's standard tools/function-calling
# protocol against the T2T_* endpoint; backends that don't support `tools`
# transparently fall back to the keyword router.
# ENABLE_LLM_ROUTER=0

# Per-LLM-request timeout in seconds (default: 300).
# LLM_TIMEOUT=300
